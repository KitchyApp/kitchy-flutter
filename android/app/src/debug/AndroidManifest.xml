<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!--
        INTERNET permission is required for the Flutter toolchain to connect
        to the Dart VM service (hot reload, hot restart, breakpoints).
    -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!--
        usesCleartextTraffic="true" overrides the "false" in the main manifest
        for DEBUG builds only (debug manifest has higher merge priority).

        tools:replace tells the Gradle manifest merger to explicitly replace
        the attribute from the main manifest instead of raising a conflict error.

        This unblocks two things in the emulator:
        1. ws:// Flutter DevTools WebSocket (Dart VM service / hot reload)
        2. http://10.0.2.2:8000 backend calls (plain HTTP in dev)
    -->
    <application
        android:usesCleartextTraffic="true"
        tools:replace="android:usesCleartextTraffic"/>

</manifest>
