<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.kitchy_app">

    <!-- Required for all HTTP calls (release, profile and debug) -->
    <uses-permission android:name="android.permission.INTERNET"/>

    <!-- Required by speech_to_text for voice recognition -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!--
        networkSecurityConfig replaces the blunt usesCleartextTraffic flag.
        It allows HTTP cleartext ONLY for 10.0.2.2 (Android emulator → host
        machine localhost) across ALL build types, while blocking cleartext
        everywhere else — including in release builds.
        See res/xml/network_security_config.xml for the per-domain rules.
    -->
    <application
        android:name="${applicationName}"
        android:label="kitchy_app"
        android:icon="@mipmap/ic_launcher"
        android:networkSecurityConfig="@xml/network_security_config">

        <!-- ADMOB -->
        <meta-data
            android:name="com.google.android.gms.ads.APPLICATION_ID"
            android:value="ca-app-pub-3940256099942544~3347511713"/>

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">

        <meta-data
            android:name="io.flutter.embedding.android.NormalTheme"
            android:resource="@style/NormalTheme" />

            <!--
                Disable Impeller on Android.
                Impeller (Flutter's new renderer, default since Flutter 3.16)
                uses Vulkan / OpenGL ES hardware acceleration that is
                incompatible with the virtual GPU drivers on x86_64 AVD
                emulators.  Tapping a TextField triggers a keyboard +
                viewport resize that causes a native crash in Impeller's
                render pass on emulated graphics hardware.
                Skia (the fallback) is stable on all architectures and
                should be re-evaluated when targeting a physical device.
            -->
            <meta-data
                android:name="io.flutter.embedding.android.EnableImpeller"
                android:value="false" />

            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>

        </activity>

        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />

    </application>

    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>

</manifest>
